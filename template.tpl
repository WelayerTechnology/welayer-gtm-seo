const injectScript = require("injectScript");
const queryPermission = require("queryPermission");
const copyFromWindow = require("copyFromWindow");
const callInWindow = require("callInWindow");
const getUrl = require("getUrl");
const getTimestampMillis = require("getTimestampMillis");
const isConsentGranted = require("isConsentGranted");
const getCookieValues = require("getCookieValues");
const setCookie = require("setCookie");
const copyFromDataLayer = require("copyFromDataLayer");
const templateStorage = require("templateStorage");

const logToConsole = require("logToConsole");


const CDN = "https://cdn.welayer.io";
const API = "https://api.welayer.io";

const SDK_NAME = "welayer-gtm-template";
const SDK_VERSION = "1.0.0";

const SCRIPT_URL = CDN + "/js/wlyr-bridge.js?v=1.0.0";
const ENDPOINT = API + "/gtm/events";

const COOKIE_CONSENT = "_wlyr_consent";
const COOKIE_VISITOR = "_wlyr_visitor";
const COOKIE_SESSION = "_wlyr_session";

const CONSENT_STORAGE_KEY = "wlyrConsentFingerprint";

function buildConsentFingerprint(consent) {
  return [
    consent.analytics_storage,
    consent.ad_storage,
    consent.ad_user_data,
    consent.ad_personalization,
    consent.functionality_storage,
    consent.personalization_storage,
    consent.security_storage
  ].join("|");
}

function resolveConsentChange(consent) {
  const currentFingerprint = buildConsentFingerprint(consent);

  const previousFingerprint = templateStorage.getItem(
    CONSENT_STORAGE_KEY
  );

  /*
   * Primera ejecución:
   * no existe estado anterior con el que comparar.
   */
  const changed =
    previousFingerprint !== undefined &&
    previousFingerprint !== null &&
    previousFingerprint !== currentFingerprint;

  templateStorage.setItem(
    CONSENT_STORAGE_KEY,
    currentFingerprint
  );

  return changed;
}

function getDefaultValue(value, fallback) {
  if (value) {
    return value;
  }

  return fallback;
}

function getCookieValue(cookieName) {
  const values = getCookieValues(cookieName);

  if (values && values.length > 0) {
    return values[0];
  }

  return null;
}

function getConsentValue(consentType) {
  if (isConsentGranted(consentType)) {
    return "granted";
  }

  return "denied";
}

function buildDebug() {
  return data.debugMode === true;
}

function debugLog(title, value) {
  if (!buildDebug()) {
    return;
  }

  logToConsole("[WeLayer] " + title);

  if (value || value === false || value === 0) {
    logToConsole(value);
  }
}

function debugStep(step, value) {
  if (!buildDebug()) {
    return;
  }

  logToConsole("========== WeLayer Debug ==========");
  logToConsole(step);

  if (value || value === false || value === 0) {
    // logToConsole(value);
  }
}

function validateConfiguration() {
  debugStep("STEP 2 - validateConfiguration()");

  const permission = queryPermission("inject_script", SCRIPT_URL);

  debugLog("Permission inject_script", permission);

  if (!permission) {
    debugLog("Permission error", "inject_script denied for " + SCRIPT_URL);
    return false;
  }

  return true;
}

function validateSendConfiguration() {
  debugStep("STEP 8 - validateSendConfiguration()");

  if (!data.authToken) {
    debugLog("Configuration error", "Missing authToken");
    return false;
  }

  if (!data.gtmId) {
    debugLog("Configuration error", "Missing gtmId");
    return false;
  }

  debugLog("Configuration OK", {
    hasAuthToken: true,
    gtmId: data.gtmId
  });

  return true;
}

function resolveEventType() {
  return copyFromDataLayer("event") || "page_view";
}

function buildPage() {
  return {
    protocol: getUrl("protocol"),
    host: getUrl("host"),
    path: getUrl("path"),
    query: getUrl("query")
  };
}

function buildNavigation() {
  return {
    source: copyFromDataLayer(
  'gtm.historyChangeSource'
),
    previousUrl: copyFromDataLayer('gtm.oldUrl'),
    currentUrl: copyFromDataLayer('gtm.newUrl'),
  };
}

function buildIdentity() {
  return {
    consentId: getCookieValue(COOKIE_CONSENT),
    visitorId: getCookieValue(COOKIE_VISITOR),
    sessionId: getCookieValue(COOKIE_SESSION)
  };
}

function buildConsent() {
  return {
    analytics_storage: getConsentValue("analytics_storage"),
    ad_storage: getConsentValue("ad_storage"),
    ad_user_data: getConsentValue("ad_user_data"),
    ad_personalization: getConsentValue("ad_personalization"),
    functionality_storage: getConsentValue("functionality_storage"),
    personalization_storage: getConsentValue("personalization_storage"),
    security_storage: getConsentValue("security_storage")
  };
}

function getDataLayerValue(key) {
  const value = copyFromDataLayer(key);

  if (value || value === false || value === 0) {
    return value;
  }

  return null;
}

function buildDataLayerPayload() {
  const eventModel = getDataLayerValue("eventModel");

  if (eventModel) {
    return eventModel;
  }

  const ecommerce = getDataLayerValue("ecommerce");

  if (ecommerce) {
    return ecommerce;
  }

  if (data.fallbackDataLayerKey) {
    const customPayload = getDataLayerValue(data.fallbackDataLayerKey);

    if (customPayload) {
      return customPayload;
    }
  }
  
  return {};
}

function buildPayload(eventType) {
  if (eventType === "consent_update") {
    return {
      legalVersion: getDefaultValue(data.legalVersion, null)
    };
  }

  return buildDataLayerPayload();
}

function buildContext() {
  const consent = buildConsent();
  const consentChanged = resolveConsentChange(consent);
  return {
    page: buildPage(),
    navigation: buildNavigation(),
    identity: buildIdentity(),
    consent: consent,
    consentChanged: consentChanged,
    debug: buildDebug(),
    legalVersion: data.legalVersion
  };
}

function buildEvent(eventType) {
  return {
    testmode: buildDebug(),
    sdk: {
      name: SDK_NAME,
      version: SDK_VERSION
    },
    type: eventType,
    service: "gtm-tracking",
    gtmId: data.gtmId,
    timestamp: getTimestampMillis(),
    context: buildContext(),
    data: buildPayload(eventType)
  };
}

function setOneCookie(cookieName, cookieValue, cookieConfig) {
  if (!cookieName) {
    debugLog("Cookie skipped", "Missing cookie name");
    return;
  }

  if (!cookieValue) {
    debugLog("Cookie skipped", "Missing cookie value for " + cookieName);
    return;
  }

  let path = "/";
  let maxAge = 31536000;
  let secure = true;
  let sameSite = "Lax";
  let domain = null;

  if (cookieConfig) {
    path = getDefaultValue(cookieConfig.path, path);
    maxAge = getDefaultValue(cookieConfig.maxAge, maxAge);
    secure = getDefaultValue(cookieConfig.secure, secure);
    sameSite = getDefaultValue(cookieConfig.sameSite, sameSite);
    domain = getDefaultValue(cookieConfig.domain, null);
  }

  const options = {
    path: path,
    "max-age": maxAge,
    secure: secure,
    samesite: sameSite
  };

  if (domain) {
    options.domain = domain;
  }

  debugLog("Set cookie", {
    name: cookieName,
    value: "[hidden]",
    options: options
  });

  setCookie(cookieName, cookieValue, options);
}

function getCookieConfig(response, cookieKey, fallbackName, fallbackMaxAge) {
  if (response.cookies && response.cookies[cookieKey]) {
    return response.cookies[cookieKey];
  }

  return {
    name: fallbackName,
    path: "/",
    maxAge: fallbackMaxAge,
    secure: true,
    sameSite: "Lax"
  };
}

function getIdentityValue(response, key) {
  if (
    response.identity &&
    response.identity[key]
  ) {
    return response.identity[key];
  }

  return response[key];
}

function deleteCookie(cookieName, cookieConfig) {

    setCookie(cookieName, "", {
        path: getDefaultValue(cookieConfig.path, "/"),
        "max-age": 0,
        secure: getDefaultValue(cookieConfig.secure, true),
        samesite: getDefaultValue(cookieConfig.sameSite, "Lax")
    });
}

function syncCookie(cookieName, value, cookieConfig) {

    if (value) {
        setOneCookie(
            getDefaultValue(cookieConfig.name, cookieName),
            value,
            cookieConfig
        );
        return;
    }

    deleteCookie(
        getDefaultValue(cookieConfig.name, cookieName),
        cookieConfig
    );
}

function storeReturnedIdentity(response) {
  debugStep("STEP 13 - storeReturnedIdentity()");

  if (!response || response.success !== true) {
    debugLog("API error", response);
    return;
  }

  const consentId = getIdentityValue(response, "consentId");
  const visitorId = getIdentityValue(response, "visitorId");
  const sessionId = getIdentityValue(response, "sessionId");

  const consentCookie = getCookieConfig(
    response,
    "consent",
    COOKIE_CONSENT,
    31536000
  );

  const visitorCookie = getCookieConfig(
    response,
    "visitor",
    COOKIE_VISITOR,
    31536000
  );

  const sessionCookie = getCookieConfig(
    response,
    "session",
    COOKIE_SESSION,
    1800
  );

  if (consentId) {
    setOneCookie(
      getDefaultValue(consentCookie.name, COOKIE_CONSENT),
      consentId,
      consentCookie
    );
  }

  syncCookie(
    COOKIE_VISITOR,
    visitorId,
    visitorCookie
  );

  syncCookie(
      COOKIE_SESSION,
      sessionId,
      sessionCookie
  );
}

function bridgeRequest(body, callback) {
  debugStep("STEP 11 - bridgeRequest()");

  const startedAt = getTimestampMillis();

  debugLog("SDK", SDK_NAME + " v" + SDK_VERSION);
  debugLog("Endpoint", "POST " + ENDPOINT);
  debugLog("Request", body);

  callInWindow("gtmApiQueue.q.push", [
    "welayer-bridge",
    {
      url: ENDPOINT,
      method: "post",
      auth: data.authToken,
      body: body
    },
    function (response) {
      const elapsed = getTimestampMillis() - startedAt;

      debugStep("STEP 12 - bridge callback()");
      debugLog("Response", response);
      debugLog("Elapsed", elapsed + " ms");

      callback(response);
    }
  ]);
}

function sendEvent(body) {
  debugStep("STEP 7 - sendEvent()");

  if (!validateSendConfiguration()) {
    debugStep("STEP 9 - validateSendConfiguration FAILED");
    data.gtmOnFailure();
    return;
  }

  debugStep("STEP 9 - validateSendConfiguration OK");
  debugStep("STEP 10 - injectScript()", SCRIPT_URL);

  injectScript(
    SCRIPT_URL,
    function () {
      debugStep("STEP 10.1 - bridge script loaded");

      const queue = copyFromWindow("gtmApiQueue");

      debugLog("gtmApiQueue", queue);

      if (!queue) {
        debugLog("Bridge error", "gtmApiQueue not found");
        data.gtmOnFailure();
        return;
      }

      bridgeRequest(body, function (result) {
        debugLog("Bridge result", result);

        if (!result) {
          debugLog("Bridge error", "Empty bridge result");
          data.gtmOnFailure();
          return;
        }

        if (!result.transportSuccess) {
          debugLog("Network error", result.error);
          data.gtmOnFailure();
          return;
        }

        if (!result.httpOk) {
          debugLog(
            "HTTP error",
            "Status " + result.httpStatus + " - " + result.statusText
          );

          debugLog("Backend error body", result.body);

          data.gtmOnFailure();
          return;
        }

        if (!result.body) {
          debugLog("Backend error", "Empty response body");
          data.gtmOnFailure();
          return;
        }

        if (result.body.success !== true) {
          debugLog("Business error", result.body);
          data.gtmOnFailure();
          return;
        }

        storeReturnedIdentity(result.body);

        debugStep("STEP 14 - gtmOnSuccess()");
        data.gtmOnSuccess();
      });
    },
    function () {
      debugLog("Bridge error", "Failed loading " + SCRIPT_URL);
      debugStep("STEP X - injectScript failure");
      data.gtmOnFailure();
    },
    "welayer_bridge"
  );
}

function main() {
  debugStep("STEP 1 - main()");

  if (!validateConfiguration()) {
    debugStep("STEP 3 - validateConfiguration FAILED");
    data.gtmOnFailure();
    return;
  }

  debugStep("STEP 3 - validateConfiguration OK");

  const eventType = resolveEventType();

  debugStep("STEP 4 - eventType", eventType);

  const eventBody = buildEvent(eventType);

  debugStep("STEP 5 - event body built", eventBody);
  debugStep("STEP 6 - calling sendEvent()");

  sendEvent(eventBody);
}

main();


