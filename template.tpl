scenarios:
- name: Consent update should succeed
  code: |-
    // Consent update should succeed

    var testData = {
      authToken: "test-token",
      gtmId: "GTM-TEST",
      legalVersion: "cookies-v1"
    };

    var sentRequest;
    var storedCookies = [];

    mock("queryPermission", function () {
      return true;
    });

    mock("getUrl", function (component) {
      if (component === "protocol") return "https";
      if (component === "host") return "example.com";
      if (component === "path") return "/";
      if (component === "query") return "";
      return "";
    });

    mock("getTimestampMillis", function () {
      return 123456789;
    });

    mock("isConsentGranted", function () {
      return true;
    });

    mock("getCookieValues", function () {
      return [];
    });

    mock("copyFromDataLayer", function (key) {
      if (key === "event") {
        return "consent_update";
      }

      return undefined;
    });

    mock("injectScript", function (url, onSuccess) {
      onSuccess();
    });

    mock("copyFromWindow", function () {
      return {};
    });

    mock("callInWindow", function (path, args) {
      sentRequest = args[1];

      args[2]({
        transportSuccess: true,
        httpStatus: 200,
        httpOk: true,
        statusText: "OK",
        body: {
          success: true,
          identity: {
            consentId: "CONSENT-1",
            visitorId: "VISITOR-1",
            sessionId: "SESSION-1"
          },
          errors: null,
          meta: {
            eventId: "EVENT-1",
            type: "consent_update"
          }
        },
        error: null
      });
    });

    mock("setCookie", function (name, value, options) {
      storedCookies.push({
        name: name,
        value: value,
        options: options
      });
    });

    runCode(testData);

    assertApi("gtmOnSuccess").wasCalled();
    assertApi("gtmOnFailure").wasNotCalled();

    assertThat(sentRequest.url)
      .isEqualTo("https://api.welayer.io/gtm/events");

    assertThat(sentRequest.method)
      .isEqualTo("post");

    assertThat(sentRequest.auth)
      .isEqualTo("test-token");

    assertThat(sentRequest.body.type)
      .isEqualTo("consent_update");

    assertThat(sentRequest.body.service)
      .isEqualTo("gtm-tracking");

    assertThat(sentRequest.body.gtmId)
      .isEqualTo("GTM-TEST");

    assertThat(sentRequest.body.data.legalVersion)
      .isEqualTo("cookies-v1");

    assertThat(
      sentRequest.body.context.consent.analytics_storage
    ).isEqualTo("granted");

    assertThat(sentRequest.body.context.page.protocol)
      .isEqualTo("https");

    assertThat(sentRequest.body.context.page.host)
      .isEqualTo("example.com");

    assertThat(storedCookies.length)
      .isEqualTo(3);

    assertThat(storedCookies[0].name)
      .isEqualTo("_wlyr_consent");

    assertThat(storedCookies[0].value)
      .isEqualTo("CONSENT-1");

    assertThat(storedCookies[1].name)
      .isEqualTo("_wlyr_visitor");

    assertThat(storedCookies[1].value)
      .isEqualTo("VISITOR-1");

    assertThat(storedCookies[2].name)
      .isEqualTo("_wlyr_session");

    assertThat(storedCookies[2].value)
      .isEqualTo("SESSION-1");
